// Esquema PostgreSQL (Supabase) — AYG Motor Racing
// Ejecutar: npx prisma migrate dev
// Requiere: POSTGRES_PRISMA_URL en .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WorkOrderStatus {
  EN_ESPERA
  DIAGNOSTICO
  EN_REPARACION
  ESPERANDO_REPUESTOS
  FINALIZADO
  ENTREGADO
}

enum SaleStatus {
  PAGADO
  PENDIENTE
  CANCELADO
}

enum PaymentMethod {
  EFECTIVO
  DEBITO
  MERCADO_PAGO
  TRANSFERENCIA
  CUENTA_CORRIENTE
}

enum StockMovementType {
  INGRESO_PROVEEDOR
  USO_TALLER
  VENTA
  AJUSTE_STOCK
  CREACION
}

enum ExpenseCategory {
  COMPRA_PROVEEDOR
  REPOSICION_STOCK
  OPERATIVO
}

enum Compatibility {
  MOTOCICLETAS
  DOS_TIEMPOS
  CUATRO_TIEMPOS
}

enum PurchaseOrderStatus {
  BORRADOR
  RECIBIDA
  CANCELADA
}

// ─── Auth & permisos ─────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  module    String
  createdAt DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id        String   @id @default(cuid())
  /// UUID de Supabase Auth cuando se integre auth externa
  authId    String?  @unique @map("auth_id")
  email     String   @unique
  name      String
  passwordHash String? @map("password_hash")
  roleId    String   @map("role_id")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role              Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  salesCreated      Sale[]            @relation("SaleCreatedBy")
  workOrdersCreated WorkOrder[]       @relation("WorkOrderCreatedBy")
  stockMovements    StockMovement[]   @relation("StockMovementCreatedBy")
  expensesCreated   Expense[]         @relation("ExpenseCreatedBy")
  purchasesCreated  SupplierPurchase[] @relation("PurchaseCreatedBy")

  @@index([roleId])
  @@map("users")
}

// ─── Configuración del negocio ───────────────────────────────────────────────

model BusinessSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_settings")
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Customer {
  id             String    @id @default(cuid())
  legacyId       String?   @unique @map("legacy_id")
  name           String
  phone          String
  email          String?
  notes          String?
  accountEnabled Boolean   @default(false) @map("account_enabled")
  /// Negativo = deuda, positivo = saldo a favor
  balance        Decimal   @default(0) @db.Decimal(12, 2)
  lastVisit      DateTime? @map("last_visit")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  motorcycles Motorcycle[]
  sales       Sale[]
  workOrders  WorkOrder[]

  @@index([name])
  @@index([phone])
  @@map("customers")
}

model Motorcycle {
  id         String   @id @default(cuid())
  legacyId   String?  @unique @map("legacy_id")
  customerId String   @map("customer_id")
  brandModel String   @map("brand_model")
  plate      String
  year       Int?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@unique([plate])
  @@index([customerId])
  @@map("motorcycles")
}

// ─── Inventario ──────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  legacyId    String?  @unique @map("legacy_id")
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subcategories Subcategory[]
  products      Product[]

  @@map("categories")
}

model Subcategory {
  id          String   @id @default(cuid())
  legacyId    String?  @unique @map("legacy_id")
  categoryId  String   @map("category_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("subcategories")
}

model Supplier {
  id        String   @id @default(cuid())
  legacyId  String?  @unique @map("legacy_id")
  name      String
  contact   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products         Product[]
  stockMovements   StockMovement[]
  expenses         Expense[]
  purchaseOrders   SupplierPurchase[]

  @@index([name])
  @@map("suppliers")
}

model Product {
  id            String          @id @default(cuid())
  legacyId      String?         @unique @map("legacy_id")
  internalCode  String          @unique @map("internal_code")
  name          String
  description   String          @db.Text
  categoryId    String          @map("category_id")
  subcategoryId String          @map("subcategory_id")
  supplierId    String          @map("supplier_id")
  imageUrl      String          @map("image_url")
  purchasePrice Decimal         @map("purchase_price") @db.Decimal(12, 2)
  publicPrice   Decimal         @map("public_price") @db.Decimal(12, 2)
  stock         Int             @default(0)
  min           Int             @default(0)
  compatibility Compatibility[]
  accent        String          @default("from-red-600 to-zinc-900")
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  category            Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory         Subcategory              @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)
  supplier            Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  stockMovements      StockMovement[]
  saleLineItems       SaleLineItem[]
  workOrderParts      WorkOrderPart[]
  purchaseOrderLines  SupplierPurchaseLine[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([supplierId])
  @@index([name])
  @@index([stock])
  @@map("products")
}

model StockMovement {
  id                 String            @id @default(cuid())
  legacyId           String?           @unique @map("legacy_id")
  productId          String            @map("product_id")
  type               StockMovementType
  quantity           Int?
  amount             Decimal?          @db.Decimal(12, 2)
  detail             String
  reference          String?
  supplierId         String?           @map("supplier_id")
  saleId             String?           @map("sale_id")
  workOrderId        String?           @map("work_order_id")
  supplierPurchaseId String?           @map("supplier_purchase_id")
  createdById        String?           @map("created_by_id")
  createdAt          DateTime          @default(now()) @map("created_at")

  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier         Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  sale             Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  workOrder        WorkOrder?        @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  supplierPurchase SupplierPurchase? @relation(fields: [supplierPurchaseId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([saleId])
  @@index([workOrderId])
  @@map("stock_movements")
}

// ─── Compras a proveedores ───────────────────────────────────────────────────

model SupplierPurchase {
  id          String              @id @default(cuid())
  legacyId    String?             @unique @map("legacy_id")
  supplierId  String              @map("supplier_id")
  reference   String?
  status      PurchaseOrderStatus @default(RECIBIDA)
  totalAmount Decimal             @map("total_amount") @db.Decimal(12, 2)
  notes       String?
  purchasedAt DateTime            @map("purchased_at")
  createdById String?             @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  supplier       Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy      User?                  @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines          SupplierPurchaseLine[]
  stockMovements StockMovement[]
  expenses       Expense[]

  @@index([supplierId])
  @@index([purchasedAt])
  @@map("supplier_purchases")
}

model SupplierPurchaseLine {
  id         String  @id @default(cuid())
  purchaseId String  @map("purchase_id")
  productId  String  @map("product_id")
  quantity   Int
  unitCost   Decimal @map("unit_cost") @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)

  purchase SupplierPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product          @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
  @@map("supplier_purchase_lines")
}

// ─── Taller ──────────────────────────────────────────────────────────────────

model WorkOrder {
  id           String          @id @default(cuid())
  legacyId     String?         @unique @map("legacy_id")
  customerId   String          @map("customer_id")
  motorcycleId String?         @map("motorcycle_id")
  problem      String          @db.Text
  observations String?         @db.Text
  status       WorkOrderStatus @default(EN_ESPERA)
  mechanic     String
  laborCost    Decimal?        @map("labor_cost") @db.Decimal(12, 2)
  createdById  String?         @map("created_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  motorcycle     Motorcycle?     @relation(fields: [motorcycleId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  parts          WorkOrderPart[]
  stockMovements StockMovement[]

  @@index([customerId])
  @@index([motorcycleId])
  @@index([status])
  @@index([createdAt])
  @@map("work_orders")
}

model WorkOrderPart {
  id           String   @id @default(cuid())
  legacyId     String?  @unique @map("legacy_id")
  workOrderId  String   @map("work_order_id")
  productId    String   @map("product_id")
  /// Snapshot al momento del uso — no cambia si el producto se renombra
  productName  String   @map("product_name")
  internalCode String   @map("internal_code")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  addedAt      DateTime @default(now()) @map("added_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([workOrderId])
  @@index([productId])
  @@map("work_order_parts")
}

// ─── Ventas ──────────────────────────────────────────────────────────────────

model Sale {
  id            String        @id @default(cuid())
  legacyId      String?       @unique @map("legacy_id")
  reference     String        @unique
  customerId    String?       @map("customer_id")
  /// Snapshot para ventas de mostrador sin cliente registrado
  customerName  String?       @map("customer_name")
  subtotal      Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  status        SaleStatus    @default(PAGADO)
  notes         String?
  createdById   String?       @map("created_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          SaleLineItem[]
  stockMovements StockMovement[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@map("sales")
}

model SaleLineItem {
  id           String  @id @default(cuid())
  legacyId     String? @unique @map("legacy_id")
  saleId       String  @map("sale_id")
  productId    String  @map("product_id")
  productName  String  @map("product_name")
  internalCode String  @map("internal_code")
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_line_items")
}

// ─── Finanzas ────────────────────────────────────────────────────────────────

model Expense {
  id                 String          @id @default(cuid())
  legacyId           String?         @unique @map("legacy_id")
  category           ExpenseCategory
  description        String
  amount             Decimal         @db.Decimal(12, 2)
  reference          String?
  supplierId         String?         @map("supplier_id")
  supplierPurchaseId String?         @unique @map("supplier_purchase_id")
  expenseDate        DateTime        @map("expense_date")
  createdById        String?         @map("created_by_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  supplier         Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierPurchase SupplierPurchase? @relation(fields: [supplierPurchaseId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([expenseDate])
  @@map("expenses")
}
