// Esquema preparado para migración a PostgreSQL (Supabase) con Prisma.
// Ejecutar: npx prisma migrate dev (cuando se conecte DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String   @id @default(cuid())
  legacyId       String?  @unique @map("legacy_id")
  name           String
  phone          String
  email          String?
  notes          String?
  accountEnabled Boolean  @default(false) @map("account_enabled")
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  lastVisit      DateTime? @map("last_visit")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  motorcycles  Motorcycle[]
  sales        CustomerSale[]
  workOrders   WorkOrder[]

  @@map("customers")
}

model Motorcycle {
  id          String   @id @default(cuid())
  legacyId    String?  @unique @map("legacy_id")
  customerId  String   @map("customer_id")
  brandModel  String   @map("brand_model")
  plate       String
  year        Int?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders  WorkOrder[]

  @@index([customerId])
  @@map("motorcycles")
}

model CustomerSale {
  id         String   @id @default(cuid())
  legacyId   String?  @unique @map("legacy_id")
  customerId String   @map("customer_id")
  reference  String
  date       DateTime
  amount     Decimal  @db.Decimal(12, 2)
  method     String
  status     String
  items      String
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_sales")
}

model WorkOrder {
  id           String   @id @default(cuid())
  legacyId     String?  @unique @map("legacy_id")
  customerId   String   @map("customer_id")
  motorcycleId String?  @map("motorcycle_id")
  problem      String
  observations String?
  status       String
  mechanic     String
  laborCost    Decimal? @map("labor_cost") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  motorcycle Motorcycle?      @relation(fields: [motorcycleId], references: [id], onDelete: SetNull)
  parts      WorkOrderPart[]

  @@index([customerId])
  @@index([motorcycleId])
  @@index([status])
  @@map("work_orders")
}

model WorkOrderPart {
  id           String   @id @default(cuid())
  legacyId     String?  @unique @map("legacy_id")
  workOrderId  String   @map("work_order_id")
  productId    String   @map("product_id")
  productName  String   @map("product_name")
  internalCode String   @map("internal_code")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  addedAt      DateTime @default(now()) @map("added_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([productId])
  @@map("work_order_parts")
}
