# ─── Prisma / PostgreSQL (obligatorio para este proyecto) ───────────────────
# Copiá desde Supabase → Settings → Database → Connection string
# "Transaction pooler" o "Prisma" → POSTGRES_PRISMA_URL
# "Direct connection" o "Session mode" sin pooler → POSTGRES_URL_NON_POOLING

POSTGRES_PRISMA_URL="postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Alias opcionales (Vercel los inyecta; no los usa Prisma directamente)
# POSTGRES_URL=
# POSTGRES_HOST=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# ─── Supabase SDK (solo si agregás Auth / Storage / Realtime con @supabase/supabase-js) ───
# Este proyecto NO los usa hoy — Prisma accede a la misma BD por postgres://, no por HTTPS.

# SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
